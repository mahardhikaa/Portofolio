pipeline {
    agent { label 'react-js' }

    environment {
        APP_DIR = "/app/project/portofolio/code"
        DOCKER_DIR = "/app/project/portofolio"
    }

    stages {

        stage('Pull Latest Code') {
            steps {
                dir("${APP_DIR}") {
                    sh 'git config --global --add safe.directory ${APP_DIR}'
                    checkout scm
                }
            }
        }

        stage('Install Dependencies') {
            steps {
                dir("${APP_DIR}") {
                    sh 'npm ci --prefer-offline --no-audit'
                }
            }
        }

        stage('Build React App') {
            steps {
                dir("${APP_DIR}") {
                    sh 'export NODE_OPTIONS="--max-old-space-size=512" && npm run build'
                }
            }
        }

        stage('Restart Nginx Container') {
            steps {
                dir("${DOCKER_DIR}") {
                    sh 'docker compose down || true'
                    sh 'docker compose up -d'
                }
            }
        }
    }
}